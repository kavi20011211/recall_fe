<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RecallApplicationGodaddyPoynt"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- First launch: merchant registration -->
        <activity
            android:name=".ui.OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.RecallApplicationGodaddyPoynt" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.RecallApplicationGodaddyPoynt">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Post-payment capture prompt — shown over lock screen on Poynt device -->
        <activity
            android:name=".ui.CapturePromptActivity"
            android:exported="false"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.RecallApplicationGodaddyPoynt" />

        <activity
            android:name=".ui.PhoneEntryActivity"
            android:exported="false"
            android:theme="@style/Theme.RecallApplicationGodaddyPoynt" />

        <activity
            android:name=".ui.ServiceSelectionActivity"
            android:exported="false"
            android:theme="@style/Theme.RecallApplicationGodaddyPoynt" />

        <activity
            android:name=".ui.SuccessActivity"
            android:exported="false"
            android:theme="@style/Theme.RecallApplicationGodaddyPoynt" />

        <receiver
            android:name=".receiver.PaymentBroadcastReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="poynt.intent.action.TRANSACTION_SUCCESS" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
